ORIONXCORE_APP_NAME=OrionXCore
ORIONXCORE_HOST=0.0.0.0
ORIONXCORE_PORT=8080
ORIONXCORE_MODEL=gpt-4.1-mini
ORIONXCORE_API_KEY=your_api_key
ORIONXCORE_API_BASE_URL=https://api.openai.com/v1
ORIONXCORE_SYSTEM_PROMPT=You are OrionXCore, a lightweight AI coding agent.
ORIONXCORE_MAX_ITERATIONS=6
ORIONXCORE_HTTP_TIMEOUT=120
ORIONXCORE_ENABLE_TERMINAL=true
ORIONXCORE_ENABLE_DATABASE=false
ORIONXCORE_TERMINAL_WORKDIR=.
ORIONXCORE_TERMINAL_TIMEOUT=30
ORIONXCORE_ALLOW_RISKY_COMMANDS=false
ORIONXCORE_DATABASE_URL=clickhousedb://username:password@localhost:8123/default
ORIONXCORE_DATABASE_MAX_ROWS=200
ORIONXCORE_DATABASE_QUERY_TIMEOUT_SECONDS=30
ORIONXCORE_DATABASE_ALLOW_MUTATION=false
ORIONXCORE_DATABASE_ALLOWED_DATABASES=default,analytics
ORIONXCORE_ENABLE_FILESYSTEM=false
ORIONXCORE_FILESYSTEM_ALLOW_WRITE=true
ORIONXCORE_FILESYSTEM_ALLOW_DELETE=false
ORIONXCORE_FILESYSTEM_MAX_READ_BYTES=1048576
ORIONXCORE_FILESYSTEM_MAX_WRITE_BYTES=1048576
ORIONXCORE_FILESYSTEM_MAX_LIST_ENTRIES=500
